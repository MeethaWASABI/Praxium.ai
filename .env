# PostgreSQL
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=praxium

# Redis
REDIS_PASSWORD=redispassword

# Environment
NODE_ENV=production
ENVIRONMENT=production

# Application endpoints (for frontend to connect to backend)
NEXT_PUBLIC_API_URL=http://localhost/api/v1

GEMINI_API_KEY="gemini_api_key_here"
PORT=3000

# Prisma
DATABASE_URL="postgresql://username:password@postgres:5432/praxium?schema=public"
DATABASE_URL_LOCAL="postgresql://username:password@localhost:5433/praxium?schema=public"
